{
  "name": "adspower-manager-desktop",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "concurrently \"npm run backend\" \"npm run frontend\"",
    "frontend": "cd frontend && npm run dev",
    "backend": "set PYTHONIOENCODING=utf-8 && py backend/server.py",
    "electron": "electron .",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\" \"wait-on http://localhost:8080 && electron .\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "wait-on": "^7.2.0"
  }
}
